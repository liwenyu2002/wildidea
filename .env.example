# Copy this file to .env and fill in your real server-side secrets.
# The .env file is ignored by git.

OPENROUTER_API_KEY=sk-or-your-key

# Optional overrides
WILDIDEA_PROVIDER=openrouter
WILDIDEA_MODEL=anthropic/claude-sonnet-4.5
WILDIDEA_JUDGE_MODEL=anthropic/claude-sonnet-4.5
WILDIDEA_DATABASE_URL=sqlite:///wildidea.db
WILDIDEA_SECRET_KEY=change-this-local-secret
WILDIDEA_SIGNUP_BONUS_CREDITS=30
WILDIDEA_RUN_CREDIT_COST=1
WILDIDEA_RUN_CARD_CAPACITY=50
WILDIDEA_USER_RUN_CARD_LIMIT=9
WILDIDEA_USER_ACTIVE_RUN_LIMIT=1
WILDIDEA_EMAIL_CODE_IP_LIMIT_PER_HOUR=80
WILDIDEA_EMAIL_CODE_ADDRESS_LIMIT_PER_HOUR=5
WILDIDEA_LOGIN_IP_LIMIT_PER_15M=60
WILDIDEA_LOGIN_ADDRESS_LIMIT_PER_15M=15
WILDIDEA_RUN_CREATE_USER_LIMIT_PER_10M=12

# SMTP email verification for registration.
WILDIDEA_SMTP_HOST=smtp.example.com
WILDIDEA_SMTP_PORT=587
WILDIDEA_SMTP_USERNAME=your-email@example.com
WILDIDEA_SMTP_PASSWORD=your-smtp-app-password
WILDIDEA_SMTP_FROM_EMAIL=your-email@example.com
WILDIDEA_SMTP_FROM_NAME=WildIdea
WILDIDEA_SMTP_STARTTLS=1
WILDIDEA_SMTP_SSL=0

# Copy to .env on the Mac mini and fill server-side secrets.

# DeepSeek official direct API.
DEEPSEEK_API_KEY=sk-your-key
WILDIDEA_PROVIDER=deepseek
WILDIDEA_MODEL=deepseek-v4-pro
WILDIDEA_JUDGE_MODEL=deepseek-v4-pro
WILDIDEA_BASE_URL=https://api.deepseek.com/v1

# Local service bind. Hermes should reverse proxy to this.
WILDIDEA_HOST=127.0.0.1
WILDIDEA_PORT=8000

# Keep runtime data outside source files.
WILDIDEA_DATABASE_URL=sqlite:///data/wildidea.db
WILDIDEA_OUTPUT_DIR=outputs/web

# Change this before production.
WILDIDEA_SECRET_KEY=change-this-production-secret
WILDIDEA_SIGNUP_BONUS_CREDITS=30
WILDIDEA_RUN_CREDIT_COST=1

# SMTP email verification for registration.
WILDIDEA_SMTP_HOST=smtp.example.com
WILDIDEA_SMTP_PORT=587
WILDIDEA_SMTP_USERNAME=your-email@example.com
WILDIDEA_SMTP_PASSWORD=your-smtp-app-password
WILDIDEA_SMTP_FROM_EMAIL=your-email@example.com
WILDIDEA_SMTP_FROM_NAME=WildIdea
WILDIDEA_SMTP_STARTTLS=1
WILDIDEA_SMTP_SSL=0

# Optional DingTalk feedback sync.
DINGTALK_SYNC_ENABLED=0
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_OPERATOR_ID=
DINGTALK_AI_TABLE_BASE_ID=
DINGTALK_FEEDBACK_SHEET_ID=
